{
  "name": "backend",
  "version": "1.0.0",
  "description": "NestJS app",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "db:dev:up": "docker-compose --file docker-compose.yml up -d || docker compose --file docker-compose.yml up -d",
    "db:dev:rm": "docker-compose --file docker-compose.yml down || docker compose --file docker-compose.yml down",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.892.0",
    "@aws-sdk/s3-request-presigner": "3.892.0",
    "@nestjs/common": "11.1.6",
    "@nestjs/config": "4.0.2",
    "@nestjs/core": "11.1.6",
    "@nestjs/platform-express": "11.1.6",
    "@nestjs/swagger": "11.2.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "exceljs": "4.4.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.10",
    "@types/node": "22.10.0",
    "typescript": "5.9.2"
  }
}
